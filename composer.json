{
    "name": "pushinbr/laravel-rabbit",
    "description": "RabbitMQ client library for Laravel with publishing, consuming, topology, TLS, confirms, failover, and security guards.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/push-in/laravel-rabbit",
    "keywords": [
        "amqp",
        "laravel",
        "queue",
        "rabbitmq"
    ],
    "authors": [
        {
            "name": "Pushin",
            "homepage": "https://github.com/push-in"
        }
    ],
    "support": {
        "issues": "https://github.com/push-in/laravel-rabbit/issues",
        "source": "https://github.com/push-in/laravel-rabbit"
    },
    "autoload": {
        "psr-4": {
            "Pushin\\LaravelRabbit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pushin\\LaravelRabbit\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/queue": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "php-amqplib/php-amqplib": "^3.7"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.5 || ^12.0 || ^13.0"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        },
        "laravel": {
            "providers": [
                "Pushin\\LaravelRabbit\\LaravelRabbitServiceProvider"
            ],
            "aliases": {
                "LaravelRabbit": "Pushin\\LaravelRabbit\\Facades\\LaravelRabbit"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:unit": "vendor/bin/phpunit --testsuite Unit",
        "test:feature": "vendor/bin/phpunit --testsuite Feature"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
